component Network Access [0.88, 0.72]
component Broadcast [0.86, 0.80]
component Physical Network [0.82, 0.70]

// Layer 2 — topology
component Mobile Topology [0.75, 0.88]
component Fibre Topology [0.74, 0.90]
component Non-Terrestrial Networks [0.72, 0.30]

// Layer 3 — space access stack
